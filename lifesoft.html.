<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LIFEソフト | アプリで生活をもっと豊かに</title>
  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #faf7f2;
      --bg2:      #f4efe6;
      --bg3:      #ede6d9;
      --accent:   #7c6a50;
      --accent2:  #b89b72;
      --text:     #2c2215;
      --muted:    #8a7a65;
      --border:   #ddd5c5;
      --card:     #fdfaf5;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', 'Hiragino Sans', 'Meiryo', sans-serif;
      line-height: 1.7;
      overflow-x: hidden;
    }
    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--accent2); border-radius: 3px; }
    /* ===== NAV ===== */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 6vw;
      background: rgba(250,247,242,0.88);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: 0.05em;
      color: var(--text);
      text-decoration: none;
    }
    .nav-logo span { color: var(--accent2); }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none;
      color: var(--muted);
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--accent); }
    /* ===== HERO ===== */
    #hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 60px 60px;
      opacity: 0.45;
      pointer-events: none;
    }
    .hero-glow {
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(184,155,114,0.15) 0%, transparent 70%);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-block;
      padding: 0.35rem 1rem;
      border: 1px solid var(--accent2);
      border-radius: 999px;
      font-size: 0.78rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
      background: rgba(184,155,114,0.1);
    }
    .hero-title {
      font-size: clamp(2.5rem, 7vw, 5.5rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }
    .hero-title .gradient {
      background: linear-gradient(135deg, var(--accent), var(--accent2), #d4a96a);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: var(--muted);
      max-width: 560px;
      margin: 0 auto 2.5rem;
    }
    .hero-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-block;
      padding: 0.75rem 2rem;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 700;
      font-size: 0.95rem;
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-primary {
      background: var(--accent);
      color: #fff;
      border: 2px solid var(--accent);
    }
    .btn-primary:hover {
      background: var(--accent2);
      border-color: var(--accent2);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(124,106,80,0.25);
    }
    .btn-ghost {
      background: transparent;
      color: var(--text);
      border: 2px solid var(--border);
    }
    .btn-ghost:hover {
      border-color: var(--accent2);
      color: var(--accent);
      transform: translateY(-2px);
    }
    /* ===== SECTIONS ===== */
    section { padding: 6rem 6vw; }
    .section-label {
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: var(--accent2);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 1.25rem;
    }
    .section-desc {
      color: var(--muted);
      max-width: 560px;
      font-size: 1.05rem;
    }
    .divider {
      width: 48px; height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 2px;
      margin: 1.25rem 0;
    }
    /* ===== ABOUT ===== */
    #about { background: var(--bg2); }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
      margin-top: 3rem;
    }
    .about-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      transition: border-color 0.3s;
    }
    .about-card:hover { border-color: var(--accent2); }
    .about-card-icon {
      font-size: 2rem;
      margin-bottom: 0.75rem;
    }
    .about-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .about-card p { color: var(--muted); font-size: 0.95rem; }
    .about-cards { display: flex; flex-direction: column; gap: 1.25rem; }
    .ceo-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.5rem;
      text-align: center;
    }
    .ceo-avatar {
      width: 80px; height: 80px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem;
      margin: 0 auto 1rem;
    }
    .ceo-card h3 { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.25rem; }
    .ceo-card .role {
      color: var(--accent2);
      font-size: 0.85rem;
      letter-spacing: 0.08em;
      margin-bottom: 1rem;
    }
    .ceo-card p { color: var(--muted); font-size: 0.95rem; }
    /* ===== SERVICES ===== */
    #services { background: var(--bg); }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .service-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 2rem;
      transition: all 0.3s;
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      transform: scaleX(0);
      transition: transform 0.3s;
    }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover {
      border-color: var(--accent2);
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(124,106,80,0.12);
    }
    .service-icon {
      width: 52px; height: 52px;
      border-radius: 12px;
      background: rgba(184,155,114,0.12);
      border: 1px solid rgba(184,155,114,0.3);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .service-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.5rem; }
    .service-card p { color: var(--muted); font-size: 0.92rem; }
    .service-tag {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.2rem 0.75rem;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .tag-dev { background: rgba(124,106,80,0.1); color: var(--accent); border: 1px solid rgba(124,106,80,0.25); }
    .tag-coming { background: rgba(180,120,60,0.08); color: #b46a20; border: 1px solid rgba(180,120,60,0.2); }
    /* ===== STATS ===== */
    .stats-bar {
      background: var(--bg3);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 3rem 6vw;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      text-align: center;
      gap: 2rem;
    }
    .stat-num {
      font-size: 2.5rem;
      font-weight: 900;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label { color: var(--muted); font-size: 0.88rem; margin-top: 0.25rem; }
    /* ===== CONTACT ===== */
    #contact { background: var(--bg2); }
    .contact-wrap {
      max-width: 680px;
      margin: 3rem auto 0;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 3rem;
    }
    .form-group { margin-bottom: 1.5rem; }
    .form-group label {
      display: block;
      font-size: 0.85rem;
      color: var(--muted);
      margin-bottom: 0.5rem;
      font-weight: 600;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      background: var(--bg3);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      padding: 0.8rem 1rem;
      font-size: 0.95rem;
      font-family: inherit;
      transition: border-color 0.2s;
      outline: none;
    }
    .form-group input:focus,
    .form-group textarea:focus { border-color: var(--accent2); }
    .form-group textarea { height: 130px; resize: vertical; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .contact-mail {
      text-align: center;
      margin-top: 2rem;
      color: var(--muted);
      font-size: 0.9rem;
    }
    .contact-mail a { color: var(--accent); text-decoration: none; }
    .contact-mail a:hover { text-decoration: underline; }
    /* ===== FOOTER ===== */
    footer {
      background: var(--bg);
      border-top: 1px solid var(--border);
      padding: 2.5rem 6vw;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-logo { font-size: 1.1rem; font-weight: 800; }
    .footer-logo span { color: var(--accent2); }
    footer p { color: var(--muted); font-size: 0.82rem; }
    /* ===== ANIMATIONS ===== */
    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    /* ===== RESPONSIVE ===== */
    @media (max-width: 768px) {
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .stats-bar { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .contact-wrap { padding: 2rem 1.5rem; }
      nav { padding: 0.9rem 1.5rem; }
      .nav-links { gap: 1.2rem; }
      section { padding: 4rem 1.5rem; }
    }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav>
    <a href="#hero" class="nav-logo">LIFE<span>ソフト</span></a>
    <ul class="nav-links">
      <li><a href="#about">会社について</a></li>
      <li><a href="#services">サービス</a></li>
      <li><a href="#contact">お問い合わせ</a></li>
    </ul>
  </nav>
  <!-- HERO -->
  <section id="hero">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-badge">🚀 アプリで世界を変える</div>
    <h1 class="hero-title">
      アプリで、生活を<br>
      <span class="gradient">もっと豊かに。</span>
    </h1>
    <p class="hero-sub">
      LIFEソフトは、人々の日常をより便利・快適にするアプリケーションを開発・提供するソフトウェア会社です。
    </p>
    <div class="hero-btns">
      <a href="#services" class="btn btn-primary">サービスを見る</a>
      <a href="#contact" class="btn btn-ghost">お問い合わせ</a>
    </div>
  </section>
  <!-- STATS -->
  <div class="stats-bar">
    <div>
      <div class="stat-num">∞</div>
      <div class="stat-label">アイデアの数</div>
    </div>
    <div>
      <div class="stat-num">100%</div>
      <div class="stat-label">ユーザー目線</div>
    </div>
    <div>
      <div class="stat-num">1</div>
      <div class="stat-label">情熱あるメンバー</div>
    </div>
  </div>
  <!-- ABOUT -->
  <section id="about">
    <div class="section-label">About Us</div>
    <h2 class="section-title">LIFEソフトについて</h2>
    <div class="divider"></div>
    <p class="section-desc">
      「アプリケーションで人々の生活をより豊かに、便利に」をコンセプトに掲げ、使いやすさと実用性にこだわったアプリを届けます。
    </p>
    <div class="about-grid">
      <div class="about-cards fade-up">
        <div class="about-card">
          <div class="about-card-icon">💡</div>
          <h3>ミッション</h3>
          <p>テクノロジーの力で、誰もの日常に小さな便利を届け続けること。</p>
        </div>
        <div class="about-card">
          <div class="about-card-icon">🎯</div>
          <h3>ビジョン</h3>
          <p>使って良かった、と思えるアプリを世に送り出し続けるソフトウェアブランドを築く。</p>
        </div>
        <div class="about-card">
          <div class="about-card-icon">⚡</div>
          <h3>バリュー</h3>
          <p>シンプル・速い・直感的。ユーザーが迷わないアプリ設計を最優先にする。</p>
        </div>
      </div>
      <div class="ceo-card fade-up">
        <div class="ceo-avatar">👤</div>
        <h3>坂本匡陽</h3>
        <div class="role">代表取締役社長 CEO</div>
        <p>
          「アプリ一つで、誰かの一日が少し楽になる。それが自分の作りたいものです。」<br><br>
          LIFEソフトの創業者であり、開発者・デザイナー・営業・サポートを一人でこなすマルチプレイヤー。
        </p>
      </div>
    </div>
  </section>
  <!-- SERVICES -->
  <section id="services">
    <div class="section-label">Services</div>
    <h2 class="section-title">サービス・アプリ紹介</h2>
    <div class="divider"></div>
    <p class="section-desc">
      日常のあらゆるシーンに寄り添う、実用的なアプリケーションを開発・提供しています。
    </p>
    <div class="services-grid">
      <div class="service-card fade-up">
        <div class="service-icon">📱</div>
        <h3>モバイルアプリ開発</h3>
        <p>iOS / Android 向けの使いやすいモバイルアプリを企画・開発。ユーザー体験を最優先に設計します。</p>
        <span class="service-tag tag-dev">開発中</span>
      </div>
      <div class="service-card fade-up">
        <div class="service-icon">🌐</div>
        <h3>Webアプリケーション</h3>
        <p>ブラウザから使えるWebアプリを開発。どのデバイスからでも快適に使えるシステムを目指します。</p>
        <span class="service-tag tag-dev">開発中</span>
      </div>
      <div class="service-card fade-up">
        <div class="service-icon">🛠️</div>
        <h3>ツール・ユーティリティ</h3>
        <p>毎日の作業を効率化する小さくて強力なツール群。地味だけど確実に役立つものを作り続けます。</p>
        <span class="service-tag tag-coming">近日公開</span>
      </div>
      <div class="service-card fade-up">
        <div class="service-icon">🤖</div>
        <h3>AI活用アプリ</h3>
        <p>最新のAI技術を取り込んだスマートなアプリケーション。未来の日常を今から体験できるサービスを提供。</p>
        <span class="service-tag tag-coming">近日公開</span>
      </div>
    </div>
  </section>
  <!-- CONTACT -->
  <section id="contact">
    <div class="section-label">Contact</div>
    <h2 class="section-title">お問い合わせ</h2>
    <div class="divider"></div>
    <p class="section-desc">
      ご質問・ご要望・コラボのご提案など、お気軽にご連絡ください。
    </p>
    <div class="contact-wrap fade-up">
      <form onsubmit="handleSubmit(event)">
        <div class="form-row">
          <div class="form-group">
            <label>お名前 *</label>
            <input type="text" placeholder="山田 太郎" required />
          </div>
          <div class="form-group">
            <label>メールアドレス *</label>
            <input type="email" placeholder="example@mail.com" required />
          </div>
        </div>
        <div class="form-group">
          <label>件名</label>
          <input type="text" placeholder="お問い合わせの内容をひとことで" />
        </div>
        <div class="form-group">
          <label>メッセージ *</label>
          <textarea placeholder="詳しい内容をご記入ください..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; border:none; font-size:1rem;">
          送信する →
        </button>
      </form>
      <div class="contact-mail">
        メールでの直接連絡は <a href="mailto:lifesoft0401@gmail.com">lifesoft0401@gmail.com</a>
      </div>
    </div>
  </section>
  <!-- FOOTER -->
  <footer>
    <div class="footer-logo">LIFE<span>ソフト</span></div>
    <p>© 2026 LIFEソフト. All rights reserved.</p>
  </footer>
  <script>
    // Fade-up animation on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    // Form submit handler
    function handleSubmit(e) {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      btn.textContent = '✅ 送信しました！';
      btn.style.background = '#7c9a6a';
      btn.disabled = true;
      setTimeout(() => {
        btn.textContent = '送信する →';
        btn.style.background = '';
        btn.disabled = false;
        e.target.reset();
      }, 3000);
    }
  </script>
</body>
</html>
